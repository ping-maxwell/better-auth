{
  "name": "@better-auth/react-ui",
  "version": "1.6.11",
  "description": "Pre-built React auth UI components for Better Auth",
  "type": "module",
  "license": "MIT",
  "homepage": "https://better-auth.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/better-auth/better-auth.git",
    "directory": "packages/react-ui"
  },
  "keywords": [
    "auth",
    "ui",
    "react",
    "components",
    "typescript",
    "better-auth"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint:package": "publint run --strict --pack false",
    "lint:types": "attw --profile esm-only --pack .",
    "typecheck": "tsc --project tsconfig.json",
    "test": "vitest"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "dev-source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.mts"
      ]
    }
  },
  "dependencies": {
    "@better-auth/ui-core": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "happy-dom": "^20.8.9",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "better-auth": "workspace:^",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  }
}
