{
  "name": "@better-auth/svelte-ui",
  "version": "1.6.11",
  "description": "Pre-built Svelte auth UI components for Better Auth",
  "type": "module",
  "license": "MIT",
  "homepage": "https://better-auth.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/better-auth/better-auth.git",
    "directory": "packages/svelte-ui"
  },
  "keywords": [
    "auth",
    "ui",
    "svelte",
    "components",
    "typescript",
    "better-auth"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --project tsconfig.json"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "dev-source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "dependencies": {
    "@better-auth/ui-core": "workspace:*"
  },
  "devDependencies": {
    "svelte": "^5.0.0",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "better-auth": "workspace:^",
    "svelte": "^5.0.0"
  }
}
